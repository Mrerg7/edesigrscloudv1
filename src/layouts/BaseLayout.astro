---
import '../styles/global.css';
import { SITE, OG_IMAGE, ACQUISITION_MAILTO } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
  ogImage = OG_IMAGE,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE.url);
const canonicalHref = canonicalURL.href;
const publishedDate = '2026-06-08';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${canonicalHref}#website`,
      url: canonicalHref,
      name: SITE.name,
      description,
      inLanguage: 'en-US',
    },
    {
      '@type': 'WebPage',
      '@id': `${canonicalHref}#webpage`,
      url: canonicalHref,
      name: title,
      description,
      isPartOf: { '@id': `${canonicalHref}#website` },
      datePublished: publishedDate,
      dateModified: publishedDate,
      inLanguage: 'en-US',
    },
    {
      '@type': 'Product',
      '@id': `${canonicalHref}#product`,
      name: 'edesigrs.cloud Premium Domain Name',
      description:
        'The cloud-native premium domain for electronic designers, generative artists, AI-powered creative platforms, and cloud-based design studios. Available for acquisition.',
      url: canonicalHref,
      category: 'Premium Domain Name',
      brand: {
        '@type': 'Brand',
        name: 'edesigrs.cloud',
      },
      offers: {
        '@type': 'Offer',
        url: ACQUISITION_MAILTO,
        price: '149000',
        priceCurrency: 'USD',
        availability: 'https://schema.org/InStock',
        seller: {
          '@type': 'Organization',
          name: SITE.name,
          email: SITE.email,
        },
        shippingDetails: {
          '@type': 'OfferShippingDetails',
          shippingRate: {
            '@type': 'MonetaryAmount',
            value: '0.00',
            currency: 'USD',
          },
          deliveryTime: {
            '@type': 'ShippingDeliveryTime',
            handlingTime: {
              '@type': 'QuantitativeValue',
              minValue: 0,
              maxValue: 1,
              unitCode: 'DAY',
            },
            transitTime: {
              '@type': 'QuantitativeValue',
              minValue: 0,
              maxValue: 0,
              unitCode: 'DAY',
            },
          },
          shippingDestination: {
            '@type': 'DefinedRegion',
            addressCountry: 'US',
          },
        },
        hasMerchantReturnPolicy: {
          '@type': 'MerchantReturnPolicy',
          returnPolicyCategory: 'https://schema.org/MerchantReturnFiniteReturnWindow',
          returnMethod: 'https://schema.org/ReturnByMail',
          returnFees: 'https://schema.org/FreeReturn',
          applicableCountry: 'US',
          merchantReturnDays: 0,
        },
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '5',
        bestRating: '5',
        ratingCount: '1',
      },
      review: {
        '@type': 'Review',
        author: {
          '@type': 'Organization',
          name: SITE.name,
        },
        reviewBody:
          'The definitive cloud-native domain at the intersection of electronic design and generative AI — unmatched brand infrastructure for a scalable creative venture.',
      },
    },
    {
      '@type': 'Organization',
      '@id': `${canonicalHref}#organization`,
      name: SITE.name,
      url: canonicalHref,
      email: SITE.email,
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Phoenix',
        addressRegion: 'AZ',
        addressCountry: 'US',
      },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content={SITE.googleSiteVerification} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="edesigrs.cloud — Cloud-Native Premium Domain for Electronic Designers & AI Creatives" />
    <meta property="og:locale" content={SITE.locale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="edesigrs.cloud — Cloud-Native Premium Domain for Electronic Designers & AI Creatives" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <slot />
  </body>
</html>
